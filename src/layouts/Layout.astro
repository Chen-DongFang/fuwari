---
import "@fontsource/roboto/400.css";
import "@fontsource/roboto/500.css";
import "@fontsource/roboto/700.css";

import ConfigCarrier from "@components/ConfigCarrier.astro";
import BrightnessControl from "@components/BrightnessControl.astro";
import MusicPlayer from "@components/MusicPlayer.astro";
import { profileConfig, siteConfig } from "@/config";
import {
	AUTO_MODE,
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	BANNER_HEIGHT_HOME,
	DARK_MODE,
	DEFAULT_THEME,
	LIGHT_MODE,
	PAGE_WIDTH,
} from "../constants/constants";
import { defaultFavicons } from "../constants/icon";
import type { Favicon } from "../types/config";
import { pathsEqual, url } from "../utils/url-utils";
import "katex/dist/katex.css";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
}

let { title, banner, description, lang, setOGTypeArticle } = Astro.props;

// apply a class to the body element to decide the height of the banner, only used for initial page load
// Swup can update the body for each page visit, but it's after the page transition, causing a delay for banner height change
// so use Swup hooks instead to change the height immediately when a link is clicked
const isHomePage = pathsEqual(Astro.url.pathname, url("/"));

// defines global css variables
// why doing this in Layout instead of GlobalStyles: https://github.com/withastro/astro/issues/6728#issuecomment-1502203757
const configHue = siteConfig.themeColor.hue;
if (!banner || typeof banner !== "string" || banner.trim() === "") {
	banner = siteConfig.banner.src;
}

// TODO don't use post cover as banner for now
banner = siteConfig.banner.src;

const enableBanner = siteConfig.banner.enable;

let pageTitle: string;
if (title) {
	pageTitle = `${title} - ${siteConfig.title}`;
} else {
	pageTitle = `${siteConfig.title} - ${siteConfig.subtitle}`;
}

const favicons: Favicon[] =
	siteConfig.favicon.length > 0 ? siteConfig.favicon : defaultFavicons;

// const siteLang = siteConfig.lang.replace('_', '-')
if (!lang) {
	lang = `${siteConfig.lang}`;
}
const siteLang = lang.replace("_", "-");

const bannerOffsetByPosition = {
	top: `${BANNER_HEIGHT_EXTEND}vh`,
	center: `${BANNER_HEIGHT_EXTEND / 2}vh`,
	bottom: "0",
};
const bannerOffset =
	bannerOffsetByPosition[siteConfig.banner.position || "center"];
---

<!DOCTYPE html>
<html lang={siteLang} class="bg-[var(--page-bg)] transition text-[14px] md:text-[16px]"
	  data-overlayscrollbars-initialize
>
	<head>

		<title>{pageTitle}</title>

		<meta charset="UTF-8" />
		<meta name="description" content={description || pageTitle}>
		<meta name="author" content={profileConfig.name}>

		<meta property="og:site_name" content={siteConfig.title}>
		<meta property="og:url" content={Astro.url}>
		<meta property="og:title" content={pageTitle}>
		<meta property="og:description" content={description || pageTitle}>
		{setOGTypeArticle ? (
        <meta property="og:type" content="article" />
        ) : (
        <meta property="og:type" content="website" />
        )}

		<meta name="twitter:card" content="summary_large_image">
		<meta property="twitter:url" content={Astro.url}>
		<meta name="twitter:title" content={pageTitle}>
		<meta name="twitter:description" content={description || pageTitle}>

		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		{favicons.map(favicon => (
			<link rel="icon"
				  href={favicon.src.startsWith('/') ? url(favicon.src) : favicon.src}
				  sizes={favicon.sizes}
				  media={favicon.theme && `(prefers-color-scheme: ${favicon.theme})`}
			/>
		))}

		<!-- Force dark mode always -->
		<script is:inline define:vars={{DEFAULT_THEME, LIGHT_MODE, DARK_MODE, AUTO_MODE, BANNER_HEIGHT_EXTEND, PAGE_WIDTH, configHue}}>
			// Always use dark mode
			document.documentElement.classList.add('dark');

			// Load the hue from local storage
			const hue = localStorage.getItem('hue') || configHue;
			document.documentElement.style.setProperty('--hue', hue);

			// calculate the --banner-height-extend, which needs to be a multiple of 4 to avoid blurry text
			let offset = Math.floor(window.innerHeight * (BANNER_HEIGHT_EXTEND / 100));
			offset = offset - offset % 4;
			document.documentElement.style.setProperty('--banner-height-extend', `${offset}px`);
		</script>
		<style define:vars={{
			configHue,
			'page-width': `${PAGE_WIDTH}rem`,
		}}></style>  <!-- defines global css variables. This will be applied to <html> <body> and some other elements idk why -->


		<slot name="head"></slot>

		<link rel="alternate" type="application/rss+xml" title={profileConfig.name} href={`${Astro.site}rss.xml`}/>

	</head>
	<body class=" min-h-screen transition " class:list={[{"lg:is-home": isHomePage, "enable-banner": enableBanner}]}
		  data-overlayscrollbars-initialize
	>
		<!-- Loading Animation (first visit only) -->
		<div id="cyber-loader" class="fixed inset-0 z-[99999] flex items-center justify-center" style="background:#050510;display:none;">
			<canvas id="loader-canvas" class="absolute inset-0" style="will-change:contents;"></canvas>
			<div class="absolute inset-0 z-[2] pointer-events-none" style="background:radial-gradient(ellipse at center,transparent 30%,rgba(5,5,16,0.92) 70%),repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,200,255,0.012) 2px,rgba(0,200,255,0.012) 4px);animation:loaderScanShift 0.08s infinite;"></div>
			<div class="relative z-[7] flex flex-col items-center gap-6" style="width:min(80vw,600px);">
				<div id="loader-bar" style="width:100%;height:3px;background:rgba(0,200,255,0.1);border-radius:3px;overflow:hidden;opacity:0;transition:opacity 0.5s ease;">
					<div id="loader-fill" style="height:100%;width:0%;background:linear-gradient(90deg,#00C8FF,#00FF88,#FFC800);border-radius:3px;transition:width 2s cubic-bezier(0.16,1,0.3,1) 0.3s;box-shadow:0 0 12px rgba(0,200,255,0.5),0 0 24px rgba(0,200,255,0.2);"></div>
				</div>
				<div class="relative">
					<div id="loader-border" style="position:absolute;top:-16px;left:50%;transform:translateX(-50%);width:clamp(240px,60vw,480px);height:1px;background:linear-gradient(90deg,transparent,#00C8FF,#FFC800,#00C8FF,transparent);opacity:0;transition:opacity 0.8s ease 1.2s;"></div>
					<div id="loader-title" style="font-size:clamp(2rem,5.5vw,4rem);font-weight:700;letter-spacing:0.15em;color:#fff;text-shadow:0 0 20px rgba(200,255,0,0.9),0 0 60px rgba(0,200,255,0.5),0 0 120px rgba(0,200,255,0.3),0 0 200px rgba(0,200,255,0.15);opacity:0;transform:translateY(20px) scale(0.95);transition:all 1.2s cubic-bezier(0.16,1,0.3,1);font-family:Georgia,'Noto Serif SC',serif;white-space:nowrap;">欢迎来到东方的赛博世界</div>
				</div>
				<div id="loader-sub" style="font-size:clamp(0.85rem,2.2vw,1.15rem);letter-spacing:0.5em;color:rgba(0,200,255,0.8);text-shadow:0 0 15px rgba(0,200,255,0.6);opacity:0;transition:all 1s ease;text-transform:uppercase;font-family:sans-serif;">CYBER WORLD LOADING...</div>
				<div class="flex items-center gap-4" style="opacity:0;" id="loader-bottom">
					<span id="loader-pct" class="font-mono" style="color:rgba(0,255,136,0.6);font-size:0.85rem;letter-spacing:0.1em;text-shadow:0 0 8px rgba(0,255,136,0.3);min-width:40px;text-align:right;">0%</span>
					<div id="loader-data" class="flex gap-4 font-mono tracking-wider" style="color:rgba(0,200,255,0.35);font-size:0.7rem;">
						<span>SYS::INIT</span><span style="color:rgba(0,200,255,0.15);">|</span><span>NET::CONNECT</span><span style="color:rgba(0,200,255,0.15);">|</span><span>MEM::ALLOC</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Cyber Scanline Effect -->
		<div class="scanline"></div>

		<!-- Cyber Particles -->
		<div id="cyber-particles"></div>

		<!-- Brightness Control -->
		<BrightnessControl></BrightnessControl>

		<!-- Music Player -->
		<MusicPlayer></MusicPlayer>

		<ConfigCarrier></ConfigCarrier>
		<slot />

		<!-- increase the page height during page transition to prevent the scrolling animation from jumping -->
		<div id="page-height-extend" class="hidden h-[300vh]"></div>
	</body>
</html>

<script is:inline>
(function() {
  var isHome = window.location.pathname === '/' || window.location.pathname === '/index.html';
  if (isHome) {
    var loader = document.getElementById('cyber-loader');
    var canvas = document.getElementById('loader-canvas');
    var ctx = canvas.getContext('2d');
    document.body.style.overflow = 'hidden';
    loader.style.display = 'flex';
    var W, H, cols = [], fontSize = 14;
    var pctEl = document.getElementById('loader-pct');
    var barEl = document.getElementById('loader-bar');
    var fillEl = document.getElementById('loader-fill');
    var bottomEl = document.getElementById('loader-bottom');
    var titleEl = document.getElementById('loader-title');
    var subEl = document.getElementById('loader-sub');
    var borderEl = document.getElementById('loader-border');
    var dpr = Math.min(window.devicePixelRatio || 1, 2);
    var density = window.innerWidth < 600 ? 3 : 1;

    // Safety: always restore scroll after 8 seconds max
    setTimeout(function() { document.body.style.overflow = ''; }, 8000);
    function resize() {
      W = window.innerWidth; H = window.innerHeight;
      canvas.width = W * dpr; canvas.height = H * dpr;
      canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      var c = Math.floor(W / fontSize);
      while (cols.length < c) cols.push(Math.random() * H / fontSize | 0);
      cols.length = c;
    }
    resize(); window.addEventListener('resize', resize);
    var chars = '歡迎來到東方的賽博世界01アイウエオカキクケコ∞∑∂∫√'.split('');
    var t = 0, phase = 0, loadPct = 0, done = false, lastPct = -1;
    function draw() {
      if (done) return;
      t += 0.016;
      ctx.fillStyle = 'rgba(5,5,16,0.04)';
      ctx.fillRect(0, 0, W, H);
      ctx.font = fontSize + 'px monospace';
      for (var i = 0; i < cols.length; i += density) {
        var ch = chars[Math.random() * chars.length | 0];
        var x = i * fontSize, y = cols[i] * fontSize;
        if (y > -fontSize && y < H + fontSize) {
          var a = 0.4 + Math.random() * 0.6;
          ctx.fillStyle = 'rgba(0,255,136,' + a + ')';
          ctx.fillText(ch, x, y);
        }
        if (y > H && Math.random() > 0.975) cols[i] = 0;
        cols[i] += 0.5 + Math.random() * 0.5;
      }
      if (phase >= 1) {
        loadPct = Math.min(100, loadPct + 1.2);
        var p = Math.floor(loadPct);
        if (p !== lastPct) { lastPct = p; pctEl.textContent = p + '%'; }
      }
      if (phase === 0 && t > 0.8) {
        phase = 1;
        barEl.style.opacity = '1';
        fillEl.style.width = '100%';
        bottomEl.style.opacity = '1';
      }
      if (phase === 1 && t > 2.2) {
        phase = 2;
        titleEl.style.opacity = '1';
        titleEl.style.transform = 'translateY(0) scale(1)';
        subEl.style.opacity = '1';
        borderEl.style.opacity = '1';
      }
      if (phase === 2 && t > 5.5) {
        phase = 3;
        done = true;
        loader.style.transition = 'opacity 1.2s ease';
        loader.style.opacity = '0';
        setTimeout(function() { loader.style.display = 'none'; loader.style.pointerEvents = 'none'; document.body.style.overflow = ''; }, 1200);
      }
      if (!done) requestAnimationFrame(draw);
    }
    draw();
  }
})();
</script>

<script is:inline>
(function() {
  const poetrySections = [
    { key: "壹·全诗", label: "壹", subtitle: "全诗", desc: "完整诗词，记录岁月与心境" },
    { key: "贰·短句", label: "贰", subtitle: "短句", desc: "灵感碎片，只言片语皆是情" },
    { key: "叁·杂选", label: "叁", subtitle: "杂选", desc: "收录佳句，他山之石可以攻玉" },
  ];

  async function loadPoetry() {
    const el = document.getElementById('poetry-content');
    const statsEl = document.getElementById('poetry-stats');
    if (!el || !statsEl) return;

    let poems = [];
    try {
      const r = await fetch('/data/poems.json');
      if (r.ok) poems = await r.json();
    } catch {}

    const sectionPoems = poetrySections.map(s => ({
      ...s,
      items: poems.filter(p => p.category === s.key).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
    }));

    statsEl.textContent = `共 ${poems.length} 首 · 壹·全诗 ${sectionPoems[0].items.length} 首 · 贰·短句 ${sectionPoems[1].items.length} 首 · 叁·杂选 ${sectionPoems[2].items.length} 首`;

    el.innerHTML = sectionPoems.map(section => `
      <div class="mb-16">
        <div class="relative mb-6 md:mb-8 py-4 md:py-6">
          <div class="flex items-center gap-3 md:gap-6">
            <div class="flex-shrink-0 w-12 h-12 md:w-20 md:h-20 rounded-full flex items-center justify-center relative" style="background: linear-gradient(135deg, rgba(255,200,0,0.1), rgba(255,0,102,0.05)); border: 1px solid rgba(255,200,0,0.2);">
              <span class="text-xl md:text-3xl font-bold" style="color: var(--cyber-gold);">${section.label}</span>
              <div class="absolute inset-0 rounded-full" style="box-shadow: 0 0 30px rgba(255,200,0,0.1);"></div>
            </div>
            <div>
              <h2 class="text-2xl md:text-3xl font-bold" style="color: rgba(255,255,255,0.9);">${section.subtitle}</h2>
              <p class="text-sm mt-1" style="color: rgba(255,255,255,0.3);">${section.desc} · ${section.items.length} 首</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, rgba(255,200,0,0.3), transparent 80%);"></div>
        </div>
        <div class="space-y-6">
          ${section.items.map(poem => `
            <div class="poem-card group relative rounded-2xl overflow-hidden transition-all duration-500" style="background: rgba(10,10,30,0.4); border: 1px solid rgba(255,255,255,0.04); backdrop-filter: blur(10px);">
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: radial-gradient(ellipse at 50% 0%, rgba(255,200,0,0.03) 0%, transparent 70%);"></div>
              <div class="absolute top-0 left-0 right-0 h-[1px] opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: linear-gradient(90deg, transparent, rgba(255,200,0,0.4), transparent);"></div>
              <div class="relative p-4 md:p-8">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4 md:mb-5">
                  <div class="flex items-center gap-2 md:gap-4">
                    <span class="text-xs md:text-sm font-mono px-2 md:px-3 py-0.5 md:py-1 rounded-lg" style="background: rgba(255,200,0,0.08); color: rgba(255,200,0,0.7); border: 1px solid rgba(255,200,0,0.12);">No.${String(poem.id).padStart(2, '0')}</span>
                    <h3 class="text-lg md:text-2xl font-bold" style="color: rgba(255,255,255,0.9);">${poem.title}</h3>
                  </div>
                  <span class="text-xs md:text-sm font-mono flex-shrink-0" style="color: rgba(255,255,255,0.2);">${poem.date}</span>
                </div>
                <div class="poem-body pl-4 md:pl-8 mb-4 md:mb-5" style="border-left: 3px solid rgba(255,200,0,0.25);">
                  <div style="color: rgba(255,255,255,0.75); line-height: 2.2; white-space: pre-line; font-size: 0.95rem; font-family: serif; letter-spacing: 0.05em;">${poem.content}</div>
                </div>
                ${poem.note ? '<div class="pl-4 md:pl-8 flex items-start gap-2" style="border-left: 3px solid rgba(0,200,255,0.2);"><span class="text-xs flex-shrink-0 mt-0.5 px-2 py-0.5 rounded" style="background: rgba(0,200,255,0.08); color: rgba(0,200,255,0.6);">创作札记</span><p class="text-xs md:text-sm" style="color: rgba(255,255,255,0.35); line-height: 1.8;">' + poem.note + '</p></div>' : ''}
                <div class="mt-3 pt-3" style="border-top: 1px solid rgba(255,255,255,0.04);">
                  <button class="poem-comment-toggle text-xs px-3 py-1.5 rounded-lg transition-all" data-poem-id="' + poem.id + '" data-poem-title="' + poem.title + '" style="color: rgba(0,200,255,0.5); background: rgba(0,200,255,0.05); border: 1px solid rgba(0,200,255,0.1);">
                    💬 评论
                  </button>
                </div>
                <div class="poem-comment-section hidden mt-4" id="poem-comment-' + poem.id + '"></div>
              </div>
            </div>
          `).join('')}
        </div>
      </div>
    `).join('');
  }

  function loadDynamicContent() {
    loadPoetry();
    setTimeout(initPoemComments, 100);
  }

  function initPoemComments() {
    document.querySelectorAll('.poem-comment-toggle').forEach(btn => {
      if (btn._initialized) return;
      btn._initialized = true;
      btn.addEventListener('click', () => {
        const poemId = btn.dataset.poemId;
        const container = document.getElementById('poem-comment-' + poemId);
        if (!container) return;

        if (!container.classList.contains('hidden')) {
          container.classList.add('hidden');
          return;
        }

        container.classList.remove('hidden');

        if (container.innerHTML) return;

        const colors = ['#00C8FF', '#FF2D95', '#B44DFF', '#FFC800', '#00FF88', '#FF6600'];
        function getColor(s) { let h=0; for(let i=0;i<s.length;i++) h=s.charCodeAt(i)+((h<<5)-h); return colors[Math.abs(h)%colors.length]; }
        function timeAgo(ts) { const d=Date.now()-new Date(ts).getTime(); const m=Math.floor(d/60000); if(m<1)return'刚刚'; if(m<60)return m+'分钟前'; const hr=Math.floor(m/60); if(hr<24)return hr+'小时前'; const dy=Math.floor(hr/24); if(dy<30)return dy+'天前'; return new Date(ts).toLocaleDateString('zh-CN'); }
        function renderOne(c) { const co=getColor(c.name); return '<div class="p-3 rounded-xl mb-2" style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.04);"><div class="flex items-center gap-2 mb-1"><span class="text-xs font-bold" style="color:'+co+';">'+c.name+'</span><span class="text-xs" style="color:rgba(255,255,255,0.2);">'+timeAgo(c.timestamp)+'</span></div><p class="text-xs leading-relaxed" style="color:rgba(255,255,255,0.55);">'+c.content+'</p></div>'; }

        container.innerHTML =
          '<div class="poem-comments-list mb-3"></div>' +
          '<div class="p-3 rounded-xl" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);">' +
            '<input class="poem-c-name w-full px-3 py-1.5 rounded-lg text-xs outline-none mb-2" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.85);" placeholder="昵称" maxlength="50">' +
            '<textarea class="poem-c-content w-full px-3 py-1.5 rounded-lg text-xs outline-none resize-none mb-2" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.85);min-height:50px;" placeholder="写评论... (Ctrl+Enter发送)" maxlength="2000"></textarea>' +
            '<div class="flex justify-between items-center"><span class="poem-c-status text-xs" style="color:rgba(255,255,255,0.3);"></span>' +
            '<button class="poem-c-submit text-xs px-3 py-1 rounded-lg" style="background:rgba(0,200,255,0.15);border:1px solid rgba(0,200,255,0.25);color:#00C8FF;">发送</button></div>' +
          '</div>';

        const savedName = localStorage.getItem('comment_name') || '';
        container.querySelector('.poem-c-name').value = savedName;

        async function loadPoemComments() {
          try {
            let data;
            try { const r = await fetch('/api/comments/poem/'+encodeURIComponent(poemId)); if(r.ok) data = await r.json(); } catch {}
            if (!data) { try { const r = await fetch('/data/comments/poem_'+poemId+'.json'); if(r.ok) data = { data: await r.json() }; } catch {} }
            if(!data)return;
            const list=container.querySelector('.poem-comments-list');
            if(!data.data||!data.data.length){list.innerHTML='<p class="text-xs text-center py-2" style="color:rgba(255,255,255,0.2);">暂无评论</p>';return;}
            list.innerHTML=data.data.map(renderOne).join('');
          } catch{}
        }

        container.querySelector('.poem-c-submit').addEventListener('click', async () => {
          const name=container.querySelector('.poem-c-name').value.trim();
          const content=container.querySelector('.poem-c-content').value.trim();
          const status=container.querySelector('.poem-c-status');
          if(!name){status.textContent='请输入昵称';status.style.color='#FF2D95';return;}
          if(!content){status.textContent='请输入内容';status.style.color='#FF2D95';return;}
          try{const r=await fetch('/api/comments/poem/'+encodeURIComponent(poemId),{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name,content})});if(r.ok){container.querySelector('.poem-c-content').value='';status.textContent='成功!';status.style.color='#00FF88';localStorage.setItem('comment_name',name);await loadPoemComments();}else{status.textContent='失败';status.style.color='#FF2D95';}}catch{status.textContent='网络错误';status.style.color='#FF2D95';}
        });

        container.querySelector('.poem-c-content').addEventListener('keydown', e => { if(e.key==='Enter'&&(e.ctrlKey||e.metaKey)) container.querySelector('.poem-c-submit').click(); });

        loadPoemComments();
      });
    });
  }

  loadDynamicContent();
  document.addEventListener('swup:contentReplaced', loadDynamicContent);

  // Visitor tracking
  try {
    fetch('/api/visitor', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ path: window.location.pathname }),
      keepalive: true,
    });
  } catch (e) {}
})();
</script>

<style is:global define:vars={{
	bannerOffset,
	'banner-height-home': `${BANNER_HEIGHT_HOME}vh`,
	'banner-height': `${BANNER_HEIGHT}vh`,
}}>
@keyframes loaderScanShift{from{transform:translateY(0)}to{transform:translateY(4px)}}
@tailwind components;
@layer components {
	.enable-banner.is-home #banner-wrapper {
