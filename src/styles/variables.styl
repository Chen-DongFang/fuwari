/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

/* Cyber Guofeng Color Palette */
:root
  /* Core brand colors */
  --cyber-cyan: #00C8FF
  --cyber-pink: #FF0066
  --cyber-gold: #FFC800
  --cyber-purple: #8A2BE2
  --cyber-green: #00FF88
  --cyber-red: #E60012
  --cyber-magenta: #FF00FF
  --cyber-blue: #0066FF
  --cyber-orange: #FF6600

  /* Background colors */
  --bg-deep: #050510
  --bg-dark: #0a0a20
  --bg-card: rgba(10, 10, 30, 0.6)
  --bg-card-hover: rgba(15, 15, 40, 0.8)
  --bg-glass: rgba(10, 10, 30, 0.7)

  /* Gradient definitions */
  --gradient-primary: linear-gradient(135deg, #FF0066, #FF6600, #FFC800)
  --gradient-cyber: linear-gradient(135deg, #00C8FF, #00FF88)
  --gradient-warm: linear-gradient(135deg, #FF0066, #FFC800)
  --gradient-cool: linear-gradient(135deg, #8A2BE2, #00C8FF)
  --gradient-hero: linear-gradient(135deg, #ff0066, #ff6600, #ffcc00, #00ff88, #00ccff, #aa44ff, #ff0066)

  /* Glow effects */
  --glow-cyan: 0 0 20px rgba(0, 200, 255, 0.3)
  --glow-pink: 0 0 20px rgba(255, 0, 102, 0.3)
  --glow-gold: 0 0 20px rgba(255, 200, 0, 0.3)
  --glow-purple: 0 0 20px rgba(138, 43, 226, 0.3)

  --radius-large 1rem
  --content-delay 150ms

/* An util to define variables that vary with light and dark mode */
define(vars)
  :root
    for key, value in vars
      {key}: value[0]
  :root.dark
    for key, value in vars
      if length(value) > 1
        {key}: value[1]

define({
  /* Primary accent - cyber cyan */
  --primary: #00C8FF #00C8FF

  /* Page background - deep dark with subtle blue */
  --page-bg: #f8f8fc #080818

  /* Card background - glassmorphism */
  --card-bg: rgba(255,255,255,0.95) rgba(10,10,30,0.6)

  /* Button content */
  --btn-content: #00C8FF #00C8FF

  /* Button regular */
  --btn-regular-bg: rgba(0,200,255,0.08) rgba(0,200,255,0.12)
  --btn-regular-bg-hover: rgba(0,200,255,0.15) rgba(0,200,255,0.2)
  --btn-regular-bg-active: rgba(0,200,255,0.22) rgba(0,200,255,0.28)

  /* Button plain */
  --btn-plain-bg-hover: rgba(0,200,255,0.06) rgba(0,200,255,0.1)
  --btn-plain-bg-active: rgba(0,200,255,0.1) rgba(0,200,255,0.15)

  /* Button card */
  --btn-card-bg-hover: rgba(0,200,255,0.06) rgba(0,200,255,0.1)
  --btn-card-bg-active: rgba(0,200,255,0.1) rgba(0,200,255,0.15)

  --enter-btn-bg: var(--btn-regular-bg)
  --enter-btn-bg-hover: var(--btn-regular-bg-hover)
  --enter-btn-bg-active: var(--btn-regular-bg-active)

  /* Deep text */
  --deep-text: #1a1a2e #e0e0f0

  /* Title active */
  --title-active: #FF0066 #FF0066

  /* Dividers */
  --line-divider: rgba(0,0,0,0.06) rgba(255,255,255,0.06)
  --line-color: rgba(0,0,0,0.08) rgba(255,255,255,0.08)
  --meta-divider: rgba(0,0,0,0.15) rgba(255,255,255,0.15)

  /* Inline code */
  --inline-code-bg: rgba(0,200,255,0.1) rgba(0,200,255,0.15)
  --inline-code-color: #00C8FF #00C8FF
  --selection-bg: rgba(0,200,255,0.2) rgba(0,200,255,0.3)
  --codeblock-selection: rgba(0,200,255,0.3)
  --codeblock-bg: #0a0a1a #0a0a1a
  --codeblock-topbar-bg: #12122a #0d0d20

  --license-block-bg: rgba(0,0,0,0.02) var(--codeblock-bg)

  /* Links */
  --link-underline: #00C8FF #00C8FF
  --link-hover: #FF0066 #FF0066
  --link-active: #FFC800 #FFC800

  /* Float panel */
  --float-panel-bg: rgba(255,255,255,0.95) rgba(10,10,30,0.85)

  /* Scrollbar */
  --scrollbar-bg-light: rgba(0,0,0,0.3)
  --scrollbar-bg-hover-light: rgba(0,0,0,0.4)
  --scrollbar-bg-active-light: rgba(0,0,0,0.5)

  --scrollbar-bg-dark: rgba(0,200,255,0.3)
  --scrollbar-bg-hover-dark: rgba(0,200,255,0.4)
  --scrollbar-bg-active-dark: rgba(0,200,255,0.5)

  --scrollbar-bg: var(--scrollbar-bg-light) var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light) var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light) var(--scrollbar-bg-active-dark)

  /* Selection bar - rainbow */
  --color-selection-bar: linear-gradient(to right, #FF0066, #FF6600, #FFC800, #00FF88, #00C8FF, #8A2BE2, #FF00FF) linear-gradient(to right, #FF0066, #FF6600, #FFC800, #00FF88, #00C8FF, #8A2BE2, #FF00FF)

  --display-light-icon: 1 0
  --display-dark-icon: 0 1

  /* Admonitions - multi-color */
  --admonitions-color-tip: #00FF88 #00FF88
  --admonitions-color-note: #00C8FF #00C8FF
  --admonitions-color-important: #8A2BE2 #8A2BE2
  --admonitions-color-warning: #FFC800 #FFC800
  --admonitions-color-caution: #FF0066 #FF0066

  /* TOC */
  --toc-badge-bg: rgba(0,200,255,0.1) var(--btn-regular-bg)
  --toc-btn-hover: rgba(0,200,255,0.08) rgba(0,200,255,0.12)
  --toc-btn-active: rgba(0,200,255,0.12) rgba(0,200,255,0.18)
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem)
  --toc-item-active: #00C8FF #00C8FF
})
