---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../config";
import { url } from "../../utils/url-utils";
import ImageWrapper from "../misc/ImageWrapper.astro";

const config = profileConfig;
---
<div class="card-base p-3 group" id="profile-card">
    <a aria-label="前往关于页面" href={url('/about/')}
       class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       max-w-[12rem] lg:max-w-none overflow-hidden rounded-xl active:scale-95">
        <div class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center">
            <Icon name="fa6-regular:address-card"
                  class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl">
            </Icon>
        </div>
        <ImageWrapper src={config.avatar || ""} alt="作者头像" class="mx-auto lg:w-full h-full lg:mt-0 rounded-xl"></ImageWrapper>
    </a>
    <div class="px-2">
        <div class="font-bold text-xl text-center mb-1 transition bg-gradient-to-r from-[var(--cyber-cyan)] to-[var(--cyber-pink)] bg-clip-text text-transparent" id="profile-name">{config.name}</div>
        <div class="h-[2px] w-12 mx-auto rounded-full mb-2 transition" style="background: linear-gradient(90deg, var(--cyber-cyan), var(--cyber-pink));"></div>
        <div class="text-center mb-2.5 transition" style="color: rgba(255,255,255,0.4);" id="profile-bio">{config.bio}</div>
        <div class="flex flex-wrap gap-2 justify-center mb-1" id="profile-links">
            {config.links.length > 1 && config.links.map(item =>
                    <a rel="me" aria-label={item.name} href={item.url} target="_blank" class="btn-regular rounded-lg h-10 w-10 active:scale-90 hover:shadow-cyber-cyan">
                        <Icon name={item.icon} class="text-[1.5rem]"></Icon>
                    </a>
            )}
            {config.links.length == 1 && <a rel="me" aria-label={config.links[0].name} href={config.links[0].url} target="_blank"
                                            class="btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95 hover:shadow-cyber-cyan">
                <Icon name={config.links[0].icon} class="text-[1.5rem]"></Icon>
                {config.links[0].name}
            </a>}
        </div>
        <div class="flex justify-center mb-1">
            <a href="mailto:2873044836@qq.com" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg transition text-xs hover:bg-[var(--btn-regular-bg-hover)]" style="color: rgba(255,255,255,0.45);">
                <Icon name="fa6-solid:envelope" class="text-[0.8rem]"></Icon>
                <span>2873044836@qq.com</span>
            </a>
        </div>
    </div>
</div>
<script is:inline>
(function() {
  async function loadDynamicProfile() {
    try {
      const r = await fetch('/api/site-data?t=' + Date.now());
      if (!r.ok) return;
      const data = await r.json();
      if (data.social && data.social.length > 0) {
        const linksEl = document.getElementById('profile-links');
        if (!linksEl) return;
        const existingLinks = linksEl.querySelectorAll('a[aria-label]');
        existingLinks.forEach(a => {
          const label = a.getAttribute('aria-label');
          const match = data.social.find(s => s.name === label);
          if (match) {
            a.href = match.url;
          }
        });
      }
      if (data.profile) {
        if (data.profile.name) {
          const nameEl = document.getElementById('profile-name');
          if (nameEl) nameEl.textContent = data.profile.name;
        }
        if (data.profile.bio) {
          const bioEl = document.getElementById('profile-bio');
          if (bioEl) bioEl.textContent = data.profile.bio;
        }
      }
    } catch (e) {}
  }
  loadDynamicProfile();
  document.addEventListener('swup:contentReplaced', loadDynamicProfile);
})();
</script>
