---
interface Props {
	size?: string;
	dot?: boolean;
	href?: string;
	label?: string;
}
const { dot, href, label }: Props = Astro.props;
---
<a href={href} aria-label={label} class="btn-regular h-8 text-sm px-3 rounded-lg hover:shadow-cyber-cyan hover:border-[var(--cyber-cyan)]/30">
    {dot && <div class="h-1 w-1 rounded-md mr-2" style="background: linear-gradient(135deg, var(--cyber-cyan), var(--cyber-pink));"></div>}
    <slot></slot>
</a>
