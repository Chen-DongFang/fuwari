---
---
<div id="brightness-control" class="fixed bottom-6 right-6 z-50">
  <!-- Toggle Button -->
  <button id="brightness-toggle" class="w-11 h-11 rounded-full flex items-center justify-center transition-all duration-300 hover:scale-110 active:scale-95" style="background: rgba(10,10,30,0.8); border: 1px solid rgba(255,200,0,0.2); backdrop-filter: blur(10px); box-shadow: 0 0 15px rgba(255,200,0,0.1);">
    <span id="brightness-icon" class="text-lg transition-all duration-300">☀</span>
  </button>

  <!-- Slider Panel -->
  <div id="brightness-panel" class="absolute bottom-14 right-0 rounded-xl p-4 opacity-0 pointer-events-none translate-y-2 transition-all duration-300" style="background: rgba(10,10,30,0.9); border: 1px solid rgba(255,200,0,0.15); backdrop-filter: blur(20px); box-shadow: 0 8px 32px rgba(0,0,0,0.4); width: 200px;">
    <div class="text-xs text-center mb-3" style="color: rgba(255,200,0,0.6); letter-spacing: 0.1em;">亮度调节</div>
    <div class="flex items-center gap-3">
      <span class="text-sm" style="color: rgba(255,255,255,0.3);">🌙</span>
      <input id="brightness-slider" type="range" min="30" max="150" value="150" class="flex-1 h-1 rounded-full appearance-none cursor-pointer" style="background: linear-gradient(90deg, rgba(255,200,0,0.2), rgba(255,200,0,0.5));">
      <span class="text-sm" style="color: rgba(255,255,255,0.3);">☀</span>
    </div>
    <div id="brightness-value" class="text-center text-xs mt-2" style="color: rgba(255,255,255,0.3);">100%</div>
  </div>
</div>

<style>
  #brightness-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--cyber-gold);
    box-shadow: 0 0 10px rgba(255,200,0,0.5);
    cursor: pointer;
  }
  #brightness-slider::-moz-range-thumb {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--cyber-gold);
    box-shadow: 0 0 10px rgba(255,200,0,0.5);
    cursor: pointer;
    border: none;
  }
</style>

<script is:inline>
(function() {
  const toggle = document.getElementById('brightness-toggle');
  const panel = document.getElementById('brightness-panel');
  const slider = document.getElementById('brightness-slider');
  const valueEl = document.getElementById('brightness-value');
  const icon = document.getElementById('brightness-icon');
  let isOpen = false;

  // Load saved brightness
  const saved = localStorage.getItem('brightness') || 150;
  slider.value = saved;
  applyBrightness(saved);

  toggle.addEventListener('click', (e) => {
    e.stopPropagation();
    isOpen = !isOpen;
    if (isOpen) {
      panel.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-2');
      panel.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
    } else {
      panel.classList.add('opacity-0', 'pointer-events-none', 'translate-y-2');
      panel.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
    }
  });

  document.addEventListener('click', (e) => {
    if (!panel.contains(e.target) && e.target !== toggle) {
      isOpen = false;
      panel.classList.add('opacity-0', 'pointer-events-none', 'translate-y-2');
      panel.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
    }
  });

  slider.addEventListener('input', (e) => {
    const val = e.target.value;
    applyBrightness(val);
    valueEl.textContent = val + '%';
    localStorage.setItem('brightness', val);
  });

  function applyBrightness(val) {
    document.documentElement.style.filter = 'brightness(' + (val / 100) + ')';
    valueEl.textContent = val + '%';
    if (val < 60) {
      icon.textContent = '🌙';
    } else if (val < 110) {
      icon.textContent = '☀';
    } else {
      icon.textContent = '🔥';
    }
  }
})();
</script>
