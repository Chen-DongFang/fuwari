---
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="留言板" description="给陈东方留言">

<div class="relative rounded-2xl overflow-hidden mb-8 p-4 md:p-12" style="background: linear-gradient(135deg, rgba(10,10,30,0.8), rgba(20,10,30,0.9)); border: 1px solid rgba(255,200,0,0.15);">
  <div class="absolute top-0 left-0 w-10 h-10 md:w-16 md:h-16 border-t-2 border-l-2 rounded-tl-2xl" style="border-color: rgba(255,200,0,0.3);"></div>
  <div class="absolute top-0 right-0 w-10 h-10 md:w-16 md:h-16 border-t-2 border-r-2 rounded-tr-2xl" style="border-color: rgba(255,200,0,0.3);"></div>
  <div class="absolute bottom-0 left-0 w-10 h-10 md:w-16 md:h-16 border-b-2 border-l-2 rounded-bl-2xl" style="border-color: rgba(255,200,0,0.3);"></div>
  <div class="absolute bottom-0 right-0 w-10 h-10 md:w-16 md:h-16 border-b-2 border-r-2 rounded-br-2xl" style="border-color: rgba(255,200,0,0.3);"></div>
  <div class="text-center relative z-10">
    <h1 class="text-3xl md:text-5xl font-bold mb-4" style="background: linear-gradient(135deg, var(--cyber-gold), var(--cyber-pink), var(--cyber-cyan)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-size: 200% 200%; animation: gradient-flow 6s ease infinite;">留言板</h1>
    <p class="text-sm md:text-lg mb-2" style="color: rgba(255,255,255,0.5);">留下你的足迹，我会看到的</p>
    <p class="text-xs md:text-sm max-w-lg mx-auto" style="color: rgba(255,255,255,0.3); line-height: 1.8;">
      任何想说的，都可以写在这里。
    </p>
  </div>
</div>

<div id="guestbook-content"></div>

<div class="text-center py-12 relative">
  <div class="h-[1px] mb-8 mx-auto max-w-md" style="background: linear-gradient(90deg, transparent, rgba(255,200,0,0.3), transparent);"></div>
  <p class="text-sm" style="color: rgba(255,255,255,0.15);">Ctrl + Enter 快速发送</p>
</div>

</MainGridLayout>
