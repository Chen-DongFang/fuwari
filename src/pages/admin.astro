---
import Layout from "../layouts/Layout.astro";
---

<Layout title="后台管理 - 陈东方的个人博客空间">
  <!-- Login Gate -->
  <div id="login-screen" class="login-screen">
    <div class="login-card">
      <div class="login-logo">⚙</div>
      <h2>管理后台</h2>
      <p>请输入账号密码登录</p>
      <input type="text" id="login-user" class="login-input" placeholder="账号" autocomplete="username">
      <input type="password" id="login-pass" class="login-input" placeholder="密码" autocomplete="current-password">
      <div id="login-error" class="login-error"></div>
      <button id="login-btn" class="login-btn">登 录</button>
    </div>
  </div>

  <!-- Admin Panel (hidden until login) -->
  <div id="admin-panel" class="admin-container" style="display:none">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="sidebar-header">
        <div class="sidebar-logo">
          <span class="logo-icon">⚙</span>
          <span class="logo-text">管理后台</span>
        </div>
        <div class="sidebar-user">
          <span class="user-name">管理员</span>
        </div>
      </div>
      
      <nav class="sidebar-nav">
        <button class="nav-item active" data-tab="site">
          <span class="nav-icon">🌐</span>
          <span class="nav-text">站点设置</span>
        </button>
        <button class="nav-item" data-tab="profile">
          <span class="nav-icon">👤</span>
          <span class="nav-text">个人资料</span>
        </button>
        <button class="nav-item" data-tab="social">
          <span class="nav-icon">🔗</span>
          <span class="nav-text">社交链接</span>
        </button>
        <button class="nav-item" data-tab="navbar">
          <span class="nav-icon">📱</span>
          <span class="nav-text">导航栏</span>
        </button>
        <button class="nav-item" data-tab="poetry">
          <span class="nav-icon">📜</span>
          <span class="nav-text">诗词管理</span>
        </button>
        <button class="nav-item" data-tab="posts">
          <span class="nav-icon">📝</span>
          <span class="nav-text">博客管理</span>
        </button>
        <button class="nav-item" data-tab="music">
          <span class="nav-icon">🎵</span>
          <span class="nav-text">音乐管理</span>
        </button>
        <button class="nav-item" data-tab="visitors">
          <span class="nav-icon">👁</span>
          <span class="nav-text">访客记录</span>
        </button>
        <button class="nav-item" data-tab="export">
          <span class="nav-icon">💾</span>
          <span class="nav-text">导出数据</span>
        </button>
      </nav>
      
      <div class="sidebar-footer">
        <a href="/" class="back-link">
          <span class="back-icon">←</span>
          <span>返回前台</span>
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-main">
      <!-- Site Settings Tab -->
      <div id="tab-site" class="tab-content active">
        <div class="tab-header">
          <h2>站点设置</h2>
          <p>管理博客的基本配置信息</p>
        </div>
        <div class="form-grid">
          <div class="form-group">
            <label>站点标题</label>
            <input type="text" id="site-title" class="form-input" placeholder="输入站点标题">
          </div>
          <div class="form-group">
            <label>副标题 / 个性签名</label>
            <input type="text" id="site-subtitle" class="form-input" placeholder="输入副标题">
          </div>
          <div class="form-group">
            <label>语言</label>
            <select id="site-lang" class="form-select">
              <option value="zh_CN">中文</option>
              <option value="en">English</option>
              <option value="ja">日本語</option>
            </select>
          </div>
          <div class="form-group">
            <label>目录深度</label>
            <input type="number" id="site-toc-depth" class="form-input" min="1" max="3" value="2">
          </div>
          <div class="form-group full-width">
            <label>Banner 图片地址</label>
            <input type="text" id="site-banner-src" class="form-input" placeholder="https://example.com/banner.jpg">
          </div>
          <div class="form-group">
            <label>启用 Banner</label>
            <label class="switch">
              <input type="checkbox" id="site-banner-enable">
              <span class="slider"></span>
            </label>
          </div>
          <div class="form-group">
            <label>启用目录</label>
            <label class="switch">
              <input type="checkbox" id="site-toc-enable" checked>
              <span class="slider"></span>
            </label>
          </div>
        </div>
        <button id="save-site" class="btn-primary">保存设置</button>
      </div>

      <!-- Profile Tab -->
      <div id="tab-profile" class="tab-content">
        <div class="tab-header">
          <h2>个人资料</h2>
          <p>管理侧边栏显示的个人信息</p>
        </div>
        <div class="form-grid">
          <div class="form-group">
            <label>昵称</label>
            <input type="text" id="profile-name" class="form-input" placeholder="输入昵称">
          </div>
          <div class="form-group">
            <label>头像路径</label>
            <input type="text" id="profile-avatar" class="form-input" placeholder="assets/images/avatar.jpg">
          </div>
          <div class="form-group full-width">
            <label>个人简介</label>
            <textarea id="profile-bio" class="form-textarea" rows="3" placeholder="输入个人简介"></textarea>
          </div>
        </div>
        <button id="save-profile" class="btn-primary">保存资料</button>
      </div>

      <!-- Social Links Tab -->
      <div id="tab-social" class="tab-content">
        <div class="tab-header">
          <h2>社交链接</h2>
          <p>管理侧边栏的社交平台链接</p>
        </div>
        <div id="social-list" class="item-list"></div>
        <button id="add-social" class="btn-secondary">+ 添加链接</button>
        <button id="save-social" class="btn-primary">保存链接</button>
      </div>

      <!-- Navbar Tab -->
      <div id="tab-navbar" class="tab-content">
        <div class="tab-header">
          <h2>导航栏</h2>
          <p>管理顶部导航栏菜单项</p>
        </div>
        <div id="navbar-list" class="item-list"></div>
        <button id="add-navbar" class="btn-secondary">+ 添加菜单</button>
        <button id="save-navbar" class="btn-primary">保存导航</button>
      </div>

      <!-- Poetry Tab -->
      <div id="tab-poetry" class="tab-content">
        <div class="tab-header">
          <h2>诗词管理</h2>
          <p>管理诗词集中的所有作品</p>
        </div>
        <div class="poetry-stats" id="poetry-stats"></div>
        <div id="poetry-list" class="item-list"></div>
        <button id="add-poetry" class="btn-secondary">+ 添加诗词</button>
        <button id="save-poetry" class="btn-primary">保存诗词</button>
      </div>

      <!-- Posts Tab -->
      <div id="tab-posts" class="tab-content">
        <div class="tab-header">
          <h2>博客管理</h2>
          <p>查看和管理已发布的博客文章</p>
        </div>
        <div id="posts-list" class="item-list"></div>
      </div>

      <!-- Music Tab -->
      <div id="tab-music" class="tab-content">
        <div class="tab-header">
          <h2>音乐管理</h2>
          <p>上传和管理背景音乐歌单</p>
        </div>
        <div id="music-upload-area" style="border:2px dashed rgba(0,247,255,0.2);border-radius:12px;padding:24px;text-align:center;margin-bottom:20px;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.borderColor='rgba(0,247,255,0.4)';this.style.background='rgba(0,247,255,0.03)'" onmouseout="this.style.borderColor='rgba(0,247,255,0.2)';this.style.background='transparent'">
          <input type="file" id="music-file" accept="audio/*" multiple style="display:none" />
          <p style="font-size:24px;margin-bottom:8px;">🎵</p>
          <p style="color:rgba(255,255,255,0.5);font-size:14px;margin-bottom:4px;">点击或拖拽音频文件到此处上传</p>
          <p style="color:rgba(255,255,255,0.3);font-size:12px;">支持 MP3 / WAV / FLAC / OGG</p>
        </div>
        <div id="music-list" class="item-list"></div>
        <div class="flex gap-3">
          <button id="save-music" class="btn-primary">保存歌单</button>
        </div>
      </div>

      <!-- Visitors Tab -->
      <div id="tab-visitors" class="tab-content">
        <div class="tab-header">
          <h2>访客记录</h2>
          <p>查看网站访客访问日志</p>
        </div>
        <div id="visitors-stats" class="poetry-stats" style="margin-bottom:20px;"></div>
        <div id="visitors-list" class="item-list"></div>
        <button id="load-more-visitors" class="btn-secondary" style="display:none;">加载更多</button>
      </div>

      <!-- Export Tab -->
      <div id="tab-export" class="tab-content">
        <div class="tab-header">
          <h2>导出数据</h2>
          <p>将修改后的数据导出为 JSON 文件</p>
        </div>
        <div class="export-options">
          <div class="export-card">
            <div class="export-icon">🌐</div>
            <h3>站点配置</h3>
            <p>导出 site-data.json</p>
            <button class="btn-export" data-export="site-data">导出</button>
          </div>
          <div class="export-card">
            <div class="export-icon">📜</div>
            <h3>诗词数据</h3>
            <p>导出 poems.json</p>
            <button class="btn-export" data-export="poems">导出</button>
          </div>
          <div class="export-card">
            <div class="export-icon">📦</div>
            <h3>全部数据</h3>
            <p>导出所有配置</p>
            <button class="btn-export" data-export="all">导出全部</button>
          </div>
        </div>
        <div class="import-section">
          <h3>导入数据</h3>
          <div class="import-area" id="import-area">
            <input type="file" id="import-file" accept=".json" hidden>
            <p>点击或拖拽 JSON 文件到此处导入</p>
            <button class="btn-secondary" id="import-btn">选择文件</button>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Toast Notification -->
  <div id="toast" class="toast hidden">
    <span id="toast-message"></span>
  </div>

  <!-- Modal -->
  <div id="modal" class="modal hidden">
    <div class="modal-overlay"></div>
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modal-title">编辑</h3>
        <button class="modal-close" id="modal-close">×</button>
      </div>
      <div id="modal-body" class="modal-body"></div>
      <div class="modal-footer">
        <button class="btn-secondary" id="modal-cancel">取消</button>
        <button class="btn-primary" id="modal-confirm">确定</button>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Reset & Base */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    background: #0a0a1a;
    color: #e0e0f0;
    line-height: 1.6;
  }

  /* Layout */
  .admin-container {
    display: flex;
    min-height: 100vh;
  }

  /* Sidebar */
  .admin-sidebar {
    width: 260px;
    background: linear-gradient(180deg, #0d0d25 0%, #0a0a1a 100%);
    border-right: 1px solid rgba(255,255,255,0.06);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 100;
  }

  .sidebar-header {
    padding: 24px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .sidebar-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .logo-icon {
    font-size: 24px;
    color: #00C8FF;
  }

  .logo-text {
    font-size: 18px;
    font-weight: 700;
    color: #fff;
  }

  .sidebar-user {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    background: rgba(0,200,255,0.08);
    border-radius: 8px;
    border: 1px solid rgba(0,200,255,0.12);
  }

  .user-name {
    color: #00C8FF;
    font-weight: 500;
  }

  .sidebar-nav {
    flex: 1;
    padding: 16px 12px;
    overflow-y: auto;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 12px 16px;
    border: none;
    background: transparent;
    color: rgba(255,255,255,0.6);
    font-size: 14px;
    cursor: pointer;
    border-radius: 8px;
    transition: all 0.2s;
    margin-bottom: 4px;
    text-align: left;
  }

  .nav-item:hover {
    background: rgba(0,200,255,0.08);
    color: #fff;
  }

  .nav-item.active {
    background: linear-gradient(135deg, rgba(0,200,255,0.15), rgba(0,200,255,0.08));
    color: #00C8FF;
    border: 1px solid rgba(0,200,255,0.2);
  }

  .nav-icon {
    font-size: 18px;
  }

  .sidebar-footer {
    padding: 16px 20px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    font-size: 13px;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #00C8FF;
  }

  /* Main Content */
  .admin-main {
    flex: 1;
    margin-left: 260px;
    padding: 32px 40px;
    min-height: 100vh;
  }

  .tab-content {
    display: none;
    animation: fadeIn 0.3s ease;
  }

  .tab-content.active {
    display: block;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .tab-header {
    margin-bottom: 32px;
  }

  .tab-header h2 {
    font-size: 28px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
  }

  .tab-header p {
    color: rgba(255,255,255,0.5);
    font-size: 14px;
  }

  /* Form */
  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 32px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-group.full-width {
    grid-column: 1 / -1;
  }

  .form-group label {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.7);
  }

  .form-input,
  .form-select,
  .form-textarea {
    padding: 12px 16px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    color: #e0e0f0;
    font-size: 14px;
    transition: all 0.2s;
    -webkit-text-fill-color: #e0e0f0;
  }

  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    outline: none;
    border-color: #00C8FF;
    box-shadow: 0 0 0 3px rgba(0,200,255,0.1);
    background: rgba(255,255,255,0.08);
  }

  .form-select option {
    background: #12122a;
    color: #e0e0f0;
  }

  .form-textarea {
    resize: vertical;
    min-height: 80px;
    line-height: 1.6;
  }

  /* Switch */
  .switch {
    position: relative;
    display: inline-block;
    width: 48px;
    height: 26px;
  }

  .switch input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255,255,255,0.1);
    border-radius: 26px;
    transition: 0.3s;
  }

  .slider:before {
    position: absolute;
    content: "";
    height: 20px;
    width: 20px;
    left: 3px;
    bottom: 3px;
    background: #fff;
    border-radius: 50%;
    transition: 0.3s;
  }

  input:checked + .slider {
    background: #00C8FF;
  }

  input:checked + .slider:before {
    transform: translateX(22px);
  }

  /* Buttons */
  .btn-primary {
    padding: 12px 24px;
    background: linear-gradient(135deg, #00C8FF, #0066FF);
    border: none;
    border-radius: 8px;
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0,200,255,0.3);
  }

  .btn-secondary {
    padding: 12px 24px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    color: rgba(255,255,255,0.7);
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s;
    margin-right: 12px;
  }

  .btn-secondary:hover {
    background: rgba(255,255,255,0.12);
    color: #fff;
  }

  /* Item List */
  .item-list {
    margin-bottom: 20px;
  }

  .item-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 16px 20px;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: all 0.2s;
  }

  .item-card:hover {
    border-color: rgba(0,200,255,0.2);
    background: rgba(0,200,255,0.05);
  }

  .item-info {
    flex: 1;
  }

  .item-name {
    font-weight: 600;
    color: #fff;
    margin-bottom: 4px;
  }

  .item-detail {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
  }

  .item-actions {
    display: flex;
    gap: 8px;
  }

  .btn-icon {
    width: 36px;
    height: 36px;
    border: 1px solid rgba(255,255,255,0.1);
    background: transparent;
    border-radius: 8px;
    color: rgba(255,255,255,0.6);
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-icon:hover {
    background: rgba(0,200,255,0.1);
    color: #00C8FF;
    border-color: rgba(0,200,255,0.3);
  }

  .btn-icon.danger:hover {
    background: rgba(255,0,102,0.1);
    color: #FF0066;
    border-color: rgba(255,0,102,0.3);
  }

  /* Poetry Stats */
  .poetry-stats {
    display: flex;
    gap: 16px;
    margin-bottom: 24px;
  }

  .stat-card {
    flex: 1;
    padding: 16px 20px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
  }

  .stat-value {
    font-size: 28px;
    font-weight: 700;
    color: #00C8FF;
  }

  .stat-label {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    margin-top: 4px;
  }

  /* Export */
  .export-options {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 40px;
  }

  .export-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 24px;
    text-align: center;
    transition: all 0.2s;
  }

  .export-card:hover {
    border-color: rgba(0,200,255,0.2);
    transform: translateY(-4px);
  }

  .export-icon {
    font-size: 40px;
    margin-bottom: 12px;
  }

  .export-card h3 {
    font-size: 16px;
    color: #fff;
    margin-bottom: 8px;
  }

  .export-card p {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 16px;
  }

  .btn-export {
    padding: 10px 24px;
    background: linear-gradient(135deg, #00C8FF, #0066FF);
    border: none;
    border-radius: 8px;
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-export:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0,200,255,0.3);
  }

  .import-section {
    margin-top: 32px;
  }

  .import-section h3 {
    font-size: 18px;
    color: #fff;
    margin-bottom: 16px;
  }

  .import-area {
    border: 2px dashed rgba(255,255,255,0.15);
    border-radius: 12px;
    padding: 40px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
  }

  .import-area:hover {
    border-color: #00C8FF;
    background: rgba(0,200,255,0.05);
  }

  .import-area p {
    color: rgba(255,255,255,0.5);
    margin-bottom: 12px;
  }

  /* Toast */
  .toast {
    position: fixed;
    bottom: 32px;
    right: 32px;
    padding: 16px 24px;
    background: linear-gradient(135deg, #00C8FF, #0066FF);
    color: #fff;
    border-radius: 12px;
    font-weight: 500;
    box-shadow: 0 8px 32px rgba(0,200,255,0.3);
    transform: translateY(100px);
    opacity: 0;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 1000;
  }

  .toast.show {
