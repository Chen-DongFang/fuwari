  window.deleteNavbar = function(index) {
    if (confirm('确定要删除这个菜单项吗？')) {
      siteData.navbar.splice(index, 1);
      renderNavbarList();
      saveData();
    }
  };

  window.editPoetry = function(index) {
    const item = poetryData[index];
    showModal('编辑诗词', `
      <div class="form-group">
        <label>标题</label>
        <input type="text" id="edit-poem-title" style="${_s}" value="${esc(item.title)}">
      </div>
      <div class="form-group">
        <label>日期</label>
        <input type="date" id="edit-poem-date" style="${_s}" value="${esc(item.date)}">
      </div>
      <div class="form-group">
        <label>分类</label>
        <select id="edit-poem-cat" style="${_s}">
          <option value="壹·全诗" ${item.category === '壹·全诗' ? 'selected' : ''}>壹·全诗</option>
          <option value="贰·短句" ${item.category === '贰·短句' ? 'selected' : ''}>贰·短句</option>
          <option value="叁·杂选" ${item.category === '叁·杂选' ? 'selected' : ''}>叁·杂选</option>
        </select>
      </div>
      <div class="form-group">
        <label>内容</label>
        <textarea id="edit-poem-content" style="${_t}"></textarea>
      </div>
      <div class="form-group">
        <label>备注</label>
        <textarea id="edit-poem-note" style="${_t}"></textarea>
      </div>
    `, () => {
      poetryData[index].title = document.getElementById('edit-poem-title').value;
      poetryData[index].date = document.getElementById('edit-poem-date').value;
      poetryData[index].category = document.getElementById('edit-poem-cat').value;
      poetryData[index].content = document.getElementById('edit-poem-content').value;
      poetryData[index].note = document.getElementById('edit-poem-note').value;
      loadPoetryTab();
      saveData();
    }, () => {
      document.getElementById('edit-poem-content').value = item.content;
      document.getElementById('edit-poem-note').value = item.note;
    });
  };

  window.deletePoetry = function(index) {
    if (confirm('确定要删除这首诗词吗？')) {
      poetryData.splice(index, 1);
      loadPoetryTab();
      saveData();
    }
  };

  window.addPoetry = function() {
    const newId = poetryData.length > 0 ? Math.max(...poetryData.map(p => p.id)) + 1 : 1;
    showModal('添加诗词', `
      <div class="form-group">
        <label>标题</label>
        <input type="text" id="edit-poem-title" style="${_s}" value="《新诗词》">
      </div>
      <div class="form-group">
        <label>日期</label>
        <input type="date" id="edit-poem-date" style="${_s}" value="${new Date().toISOString().split('T')[0]}">
      </div>
      <div class="form-group">
        <label>分类</label>
        <select id="edit-poem-cat" style="${_s}">
          <option value="壹·全诗">壹·全诗</option>
          <option value="贰·短句">贰·短句</option>
          <option value="叁·杂选">叁·杂选</option>
        </select>
      </div>
      <div class="form-group">
        <label>内容</label>
        <textarea id="edit-poem-content" style="${_t}" placeholder="输入诗词内容"></textarea>
      </div>
      <div class="form-group">
        <label>备注</label>
        <textarea id="edit-poem-note" style="${_t}" placeholder="输入备注"></textarea>
      </div>
    `, () => {
      poetryData.push({
        id: newId,
        title: document.getElementById('edit-poem-title').value,
        date: document.getElementById('edit-poem-date').value,
        category: document.getElementById('edit-poem-cat').value,
        content: document.getElementById('edit-poem-content').value,
        note: document.getElementById('edit-poem-note').value
      });
      loadPoetryTab();
      saveData();
    });
  };

  window.viewPost = function(slug) {
    window.open(`/posts/${slug}`, '_blank');
  };

  // Export
  function setupExport() {
    document.querySelectorAll('.btn-export').forEach(btn => {
      btn.addEventListener('click', () => {
        const type = btn.dataset.export;
        let data, filename;
        if (type === 'site-data') {
          data = siteData;
          filename = 'site-data.json';
        } else if (type === 'poems') {
          data = poetryData;
          filename = 'poems.json';
        } else {
          data = { siteData, poetryData };
          filename = 'blog-all-data.json';
        }
        const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        a.click();
        URL.revokeObjectURL(url);
        showToast(`${filename} 已导出`);
      });
    });
  }

  // Import
  function setupImport() {
    const importArea = document.getElementById('import-area');
    const importBtn = document.getElementById('import-btn');
    const importFile = document.getElementById('import-file');

    importBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      importFile.click();
    });

    importArea.addEventListener('click', () => importFile.click());

    importFile.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (event) => {
        try {
          const data = JSON.parse(event.target.result);
          if (data.site) {
            siteData = data;
          } else if (data.siteData) {
            siteData = data.siteData;
            if (data.poetryData) poetryData = data.poetryData;
          } else if (Array.isArray(data)) {
            poetryData = data;
          }
          loadAllTabs();
          saveData();
          showToast('数据导入成功');
        } catch (err) {
          showToast('导入失败：文件格式错误');
        }
      };
      reader.readAsText(file);
    });

    importArea.addEventListener('dragover', (e) => {
      e.preventDefault();
      importArea.style.borderColor = '#00C8FF';
    });

    importArea.addEventListener('dragleave', () => {
      importArea.style.borderColor = '';
    });

    importArea.addEventListener('drop', (e) => {
      e.preventDefault();
      importArea.style.borderColor = '';
      const file = e.dataTransfer.files[0];
      if (file) {
        importFile.files = e.dataTransfer.files;
        importFile.dispatchEvent(new Event('change'));
      }
    });
  }

  // Run
  init();
</script>
