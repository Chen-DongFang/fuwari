<script>
  // Login Gate
  const ADMIN_USER = "admin";
  const ADMIN_PASS = "Aa@314159";

  function checkLogin() {
    return sessionStorage.getItem("admin_logged_in") === "true";
  }

  function showAdmin() {
    document.getElementById("login-screen").style.display = "none";
    document.getElementById("admin-panel").style.display = "flex";
  }

  function setupLogin() {
    const loginBtn = document.getElementById("login-btn");
    const userInput = document.getElementById("login-user");
    const passInput = document.getElementById("login-pass");
    const errorEl = document.getElementById("login-error");

    function doLogin() {
      const u = userInput.value.trim();
      const p = passInput.value;
      if (u === ADMIN_USER && p === ADMIN_PASS) {
        sessionStorage.setItem("admin_logged_in", "true");
        showAdmin();
        init();
      } else {
        errorEl.textContent = "账号或密码错误";
        passInput.value = "";
        passInput.focus();
      }
    }

    loginBtn.addEventListener("click", doLogin);
    passInput.addEventListener("keydown", (e) => { if (e.key === "Enter") doLogin(); });
    userInput.addEventListener("keydown", (e) => { if (e.key === "Enter") passInput.focus(); });
  }

  // Init
  if (checkLogin()) {
    showAdmin();
    init();
  } else {
    setupLogin();
  }

  // API Config
  const API_BASE = location.origin;
  const AUTH_TOKEN = 'admin.Aa@314159';
  async function apiGet(filename) {
    const r = await fetch(`${API_BASE}/api/data/${filename}`, { headers: { Authorization: `Bearer ${AUTH_TOKEN}` } });
    if (!r.ok) throw new Error(`GET ${filename} failed`);
    return (await r.json()).data;
  }
  async function apiPost(filename, data) {
    const r = await fetch(`${API_BASE}/api/data/${filename}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${AUTH_TOKEN}` },
      body: JSON.stringify(data),
    });
    if (!r.ok) throw new Error(`POST ${filename} failed`);
    return await r.json();
  }

  let apiAvailable = false;

  // Data Store
  let siteData = {
    site: {
      title: "陈东方的个人博客空间",
      subtitle: "万千芳华入盏中，举杯共赏论红尘。",
      lang: "zh_CN",
      banner: { enable: false, src: "", position: "center" },
      toc: { enable: true, depth: 2 }
    },
    profile: {
      name: "陈东方",
      bio: "盛夏的蝉鸣难以颤动孤寂的心，唯有热爱的薪火，总在寒夜里点燃那片潮湿的魂。",
      avatar: "assets/images/avatar.jpg"
    },
    social: [
      { name: "GitHub", icon: "fa6-brands:github", url: "https://github.com/Chen-DongFang" },
      { name: "QQ空间", icon: "fa6-brands:qq", url: "https://user.qzone.qq.com/2873044836" },
      { name: "哔哩哔哩", icon: "fa6-brands:bilibili", url: "https://space.bilibili.com/110526898" },
      { name: "Steam", icon: "fa6-brands:steam", url: "https://store.steampowered.com" }
    ],
    navbar: [
      { type: "home", name: "首页", url: "/" },
      { type: "archive", name: "归档", url: "/archive" },
      { type: "custom", name: "诗词", url: "/poetry/" },
      { type: "about", name: "关于", url: "/about" },
      { type: "custom", name: "GitHub", url: "https://github.com/Chen-DongFang", external: true }
    ],
    license: { enable: true, name: "CC BY-NC-SA 4.0", url: "https://creativecommons.org/licenses/by-nc-sa/4.0/" }
  };

  let poetryData = [];
  let postsData = [];

  function esc(str) {
    const d = document.createElement('div');
    d.textContent = str || '';
    return d.innerHTML;
  }

  const _s = 'background:rgba(255,255,255,0.08);color:#e0e0f0;border:1px solid rgba(255,255,255,0.15);-webkit-text-fill-color:#e0e0f0;padding:12px 16px;border-radius:8px;font-size:14px;width:100%;box-sizing:border-box;outline:none;';
  const _t = _s + 'resize:vertical;min-height:80px;line-height:1.6;';

  // Initialize
  async function init() {
    await loadData();
    setupNavigation();
    setupModals();
    setupExport();
    setupImport();
    loadAllTabs();
  }

  async function loadData() {
    // Try API first
    try {
      const poems = await apiGet('poems.json');
      poetryData = poems;
      apiAvailable = true;
    } catch (e) {
      console.log('API unavailable, trying local files');
      try {
        const poemsResponse = await fetch('/data/poems.json');
        if (poemsResponse.ok) {
          poetryData = await poemsResponse.json();
        }
      } catch (e2) {
        console.log('Failed to load poems.json');
      }
    }

    // Try loading site-data from API
    if (apiAvailable) {
      try {
        const sd = await apiGet('site-data.json');
        siteData = { ...siteData, ...sd };
      } catch (e) { /* ignore */ }
    }

    // Override with localStorage (last session)
    try {
      const saved = localStorage.getItem('admin_data');
      if (saved) {
        const parsed = JSON.parse(saved);
        if (!apiAvailable) siteData = { ...siteData, ...parsed.siteData };
        if (parsed.poetryData && parsed.poetryData.length > 0) {
          poetryData = parsed.poetryData;
        }
      }
    } catch (e) { /* ignore */ }
  }

  async function saveData() {
    localStorage.setItem('admin_data', JSON.stringify({ siteData, poetryData }));
    if (apiAvailable) {
      try {
        await apiPost('poems.json', poetryData);
        await apiPost('site-data.json', siteData);
        showToast('已保存到服务器');
      } catch (e) {
        showToast('已保存到本地（服务器写入失败）');
      }
    } else {
      showToast('已保存到本地');
    }
  }

  // Navigation
  function setupNavigation() {
    document.querySelectorAll('.nav-item').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
        const tab = document.getElementById(`tab-${btn.dataset.tab}`);
        if (tab) tab.classList.add('active');
      });
    });
  }

  // Load Tabs
  function loadAllTabs() {
    loadSiteTab();
    loadProfileTab();
    loadSocialTab();
    loadNavbarTab();
    loadPoetryTab();
    loadPostsTab();
    loadMusicTab();
    loadVisitorsTab();
  }

  function loadSiteTab() {
    document.getElementById('site-title').value = siteData.site.title;
    document.getElementById('site-subtitle').value = siteData.site.subtitle;
    document.getElementById('site-lang').value = siteData.site.lang;
    document.getElementById('site-banner-src').value = siteData.site.banner.src;
    document.getElementById('site-banner-enable').checked = siteData.site.banner.enable;
    document.getElementById('site-toc-enable').checked = siteData.site.toc.enable;
    document.getElementById('site-toc-depth').value = siteData.site.toc.depth;

    document.getElementById('save-site').addEventListener('click', () => {
      siteData.site.title = document.getElementById('site-title').value;
      siteData.site.subtitle = document.getElementById('site-subtitle').value;
      siteData.site.lang = document.getElementById('site-lang').value;
      siteData.site.banner.src = document.getElementById('site-banner-src').value;
      siteData.site.banner.enable = document.getElementById('site-banner-enable').checked;
      siteData.site.toc.enable = document.getElementById('site-toc-enable').checked;
      siteData.site.toc.depth = parseInt(document.getElementById('site-toc-depth').value);
      saveData();
    });
  }

  function loadProfileTab() {
    document.getElementById('profile-name').value = siteData.profile.name;
    document.getElementById('profile-bio').value = siteData.profile.bio;
    document.getElementById('profile-avatar').value = siteData.profile.avatar;

    document.getElementById('save-profile').addEventListener('click', () => {
      siteData.profile.name = document.getElementById('profile-name').value;
      siteData.profile.bio = document.getElementById('profile-bio').value;
      siteData.profile.avatar = document.getElementById('profile-avatar').value;
      saveData();
    });
  }

  function loadSocialTab() {
    renderSocialList();
    document.getElementById('add-social').addEventListener('click', () => {
      siteData.social.push({ name: "新链接", icon: "fa6-brands:link", url: "#" });
      renderSocialList();
    });
    document.getElementById('save-social').addEventListener('click', saveData);
  }

  function renderSocialList() {
    const list = document.getElementById('social-list');
    list.innerHTML = siteData.social.map((item, i) => `
      <div class="item-card">
        <div class="item-info">
          <div class="item-name">${item.name}</div>
          <div class="item-detail">${item.url}</div>
        </div>
        <div class="item-actions">
          <button class="btn-icon" onclick="editSocial(${i})">✏</button>
          <button class="btn-icon danger" onclick="deleteSocial(${i})">🗑</button>
        </div>
      </div>
    `).join('');
  }

  function loadNavbarTab() {
    renderNavbarList();
    document.getElementById('add-navbar').addEventListener('click', () => {
      siteData.navbar.push({ type: "custom", name: "新菜单", url: "/" });
      renderNavbarList();
    });
    document.getElementById('save-navbar').addEventListener('click', saveData);
  }

  function renderNavbarList() {
    const list = document.getElementById('navbar-list');
    list.innerHTML = siteData.navbar.map((item, i) => `
      <div class="item-card">
        <div class="item-info">
          <div class="item-name">${item.name}</div>
          <div class="item-detail">${item.url}${item.external ? ' (外部链接)' : ''}</div>
        </div>
        <div class="item-actions">
          <button class="btn-icon" onclick="editNavbar(${i})">✏</button>
          <button class="btn-icon danger" onclick="deleteNavbar(${i})">🗑</button>
        </div>
      </div>
    `).join('');
  }

  function loadPoetryTab() {
    const stats = document.getElementById('poetry-stats');
    const poems = poetryData.length > 0 ? poetryData : [];
    stats.innerHTML = `
      <div class="stat-card">
        <div class="stat-value">${poems.length}</div>
        <div class="stat-label">总诗词数</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">${poems.filter(p => p.category === '壹·全诗').length}</div>
        <div class="stat-label">全诗</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">${poems.filter(p => p.category === '贰·短句').length}</div>
        <div class="stat-label">短句</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">${poems.filter(p => p.category === '叁·杂选').length}</div>
        <div class="stat-label">杂选</div>
      </div>
    `;
    renderPoetryList();
    document.getElementById('add-poetry').addEventListener('click', addPoetry);
    document.getElementById('save-poetry').addEventListener('click', saveData);
  }

  function renderPoetryList() {
    const list = document.getElementById('poetry-list');
    list.innerHTML = poetryData.map((item, i) => `
      <div class="item-card">
        <div class="item-info">
          <div class="item-name">${item.title} — ${item.date}</div>
          <div class="item-detail">${item.category} | ${item.content.substring(0, 30)}...</div>
        </div>
        <div class="item-actions">
          <button class="btn-icon" onclick="editPoetry(${i})">✏</button>
          <button class="btn-icon danger" onclick="deletePoetry(${i})">🗑</button>
        </div>
      </div>
    `).join('');
  }

  // ========== Music Management ==========
  let musicData = [];

  async function loadMusicTab() {
    try {
      const r = await fetch('/api/music', { headers: { Authorization: 'Bearer ' + AUTH_TOKEN } });
      if (r.ok) { const d = await r.json(); musicData = d.data || []; }
    } catch {}
    renderMusicList();

    // Upload area
    const uploadArea = document.getElementById('music-upload-area');
    const fileInput = document.getElementById('music-file');
    uploadArea.addEventListener('click', () => fileInput.click());
    uploadArea.addEventListener('dragover', (e) => { e.preventDefault(); e.stopPropagation(); });
    uploadArea.addEventListener('drop', (e) => {
      e.preventDefault(); e.stopPropagation();
      uploadMusicFiles(e.dataTransfer.files);
    });
    fileInput.addEventListener('change', (e) => uploadMusicFiles(e.target.files));

    document.getElementById('save-music').addEventListener('click', async () => {
      try {
        await apiPost('music.json', musicData);
        showToast('歌单已保存到服务器');
      } catch (e) { showToast('保存失败: ' + e.message); }
    });
  }

  function renderMusicList() {
    const list = document.getElementById('music-list');
    if (!musicData.length) {
      list.innerHTML = '<p style="color:rgba(255,255,255,0.3);text-align:center;padding:20px;">暂无音乐，点击上方上传</p>';
      return;
    }
    list.innerHTML = musicData.map((t, i) => `
      <div class="item-card">
        <div class="item-info">
          <div class="item-name">${esc(t.title)}</div>
          <div class="item-detail">${esc(t.artist)} | ${t.file}</div>
        </div>
        <div class="item-actions">
          <button class="btn-icon" onclick="window._admin.playMusic(${i})" title="播放">▶</button>
          <button class="btn-icon danger" onclick="window._admin.deleteMusic('${t.id}')" title="删除">🗑</button>
        </div>
      </div>
    `).join('');
  }

  async function uploadMusicFiles(files) {
    if (!files || !files.length) return;
    for (const f of files) {
      const formData = new FormData();
      formData.append('file', f);
      formData.append('title', f.name.replace(/\.[^/.]+$/, '').split(' - ').pop() || f.name);
      formData.append('artist', f.name.split(' - ')[0] || '未知');
      try {
        const r = await fetch('/api/music/upload', {
          method: 'POST',
          headers: { Authorization: 'Bearer ' + AUTH_TOKEN },
          body: formData,
        });
        if (r.ok) {
          const d = await r.json();
          if (d.tracks) musicData.push(...d.tracks);
        }
      } catch (e) { showToast('上传失败: ' + e.message); }
    }
    renderMusicList();
    showToast('上传完成');
  }

  window._admin = window._admin || {};
  window._admin.playMusic = function(index) {
    const track = musicData[index];
    if (!track) return;
    const w = window.open('', '_blank');
    w.document.write('<audio src="' + track.file + '" autoplay controls style="width:100%;margin:40px auto;display:block;max-width:500px;"></audio><h2 style="text-align:center;color:#fff;background:#0a0a1a;padding:20px;font-family:sans-serif;">' + track.title + ' - ' + track.artist + '</h2>');
    w.document.body.style.background = '#0a0a1a';
  };

  window._admin.deleteMusic = async function(id) {
    if (!confirm('确定要删除这首音乐吗？')) return;
    try {
      await fetch('/api/music/' + id, { method: 'DELETE', headers: { Authorization: 'Bearer ' + AUTH_TOKEN } });
      musicData = musicData.filter(t => t.id !== id);
      renderMusicList();
      showToast('已删除');
    } catch (e) { showToast('删除失败'); }
  };

  // ========== Visitors ==========
  let visitorsOffset = 0;
  const VISITORS_PER_PAGE = 50;

  async function loadVisitorsTab() {
    visitorsOffset = 0;
    await fetchVisitors();
    document.getElementById('load-more-visitors').onclick = async function() {
      await fetchVisitors();
    };
  }

  async function fetchVisitors() {
    try {
      const r = await fetch('/api/visitor?limit=' + VISITORS_PER_PAGE + '&offset=' + visitorsOffset, { headers: { Authorization: 'Bearer ' + AUTH_TOKEN } });
      if (!r.ok) return;
      const d = await r.json();
      const total = d.total || 0;
      const data = d.data || [];

      document.getElementById('visitors-stats').innerHTML =
        '<div class="stat-card"><div class="stat-value">' + total + '</div><div class="stat-label">总访客数</div></div>' +
        '<div class="stat-card"><div class="stat-value">' + getTodayVisits(total, data) + '</div><div class="stat-label">今日访问</div></div>' +
        '<div class="stat-card"><div class="stat-value">' + data.length + '</div><div class="stat-label">本页</div></div>';

      const list = document.getElementById('visitors-list');
      const html = data.map(function(v) {
        const t = new Date(v.timestamp);
        const timeStr = t.toLocaleString('zh-CN', { month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit' });
        const ipShort = v.ip ? v.ip.replace(/::ffff:/, '').slice(0, 15) : '未知';
        const isMobile = /Mobile|Android|iPhone|iPad/i.test(v.ua || '');
        const browser = (v.ua || '').match(/Chrome|Firefox|Safari|Edge|Opera/i)?.[0] || '其他';
        return '<div class="item-card">' +
          '<div class="item-info">' +
            '<div class="item-name" style="font-family:monospace;font-size:13px;">' + ipShort + '</div>' +
            '<div class="item-detail">' + timeStr + ' · ' + v.path + ' · ' + browser + (isMobile ? ' 📱' : ' 💻') + '</div>' +
          '</div>' +
        '</div>';
      }).join('');

      if (visitorsOffset === 0) list.innerHTML = html;
      else list.innerHTML += html;

      visitorsOffset += data.length;
      document.getElementById('load-more-visitors').style.display = visitorsOffset < total ? 'block' : 'none';
    } catch (e) { console.error(e); }
  }

  function getTodayVisits(total, recentData) {
    const today = new Date().toDateString();
    return recentData.filter(function(v) { return new Date(v.timestamp).toDateString() === today; }).length;
  }

  function loadPostsTab() {
    const list = document.getElementById('posts-list');
    list.innerHTML = `
      <div class="item-card">
        <div class="item-info">
